generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  pending
  approved
  hidden
  rejected
}

enum ImportMode {
  create_only
  upsert
}

enum ImportStatus {
  processing
  completed
  partial
  failed
}

enum ReviewIdentityType {
  legacy
  student
}

model AdminUser {
  id             Int           @id @default(autoincrement())
  username       String        @unique
  passwordHash   String
  passwordVersion Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reviews        BookReview[]  @relation("ReviewedBy")
  editedReviews  BookReview[]  @relation("EditedBy")
  importBatches  ImportBatch[]
}

model Book {
  id                  Int          @id @default(autoincrement())
  bookId              String       @unique
  title               String
  normalizedTitle     String
  author              String
  publishPlace        String?
  publisher           String
  publishDateText     String?
  barcode             String?
  isbn                String?
  callNumber          String?
  subtitle            String?
  categoryCode        String?
  categoryLabel       String?
  publishYear         Int?
  publishDecade       String?
  totalCopies         Int
  availableCopies     Int
  sourceImportBatchId Int?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  reviews             BookReview[]
  sourceImportBatch   ImportBatch? @relation(fields: [sourceImportBatchId], references: [id], onDelete: SetNull)

  @@index([normalizedTitle])
}

model BookReview {
  id                  Int                @id @default(autoincrement())
  bookId              Int?
  displayName         String
  originalContent     String
  finalContent        String
  status              ReviewStatus       @default(pending)
  identityType        ReviewIdentityType @default(legacy)
  studentRosterId     Int?
  studentSystemId     String?
  studentName         String?
  studentClassName    String?
  studentIdCardSuffix String?
  sensitiveHit        Boolean            @default(false)
  matchedSensitiveWords Json?
  isFeatured          Boolean            @default(false)
  featuredOrder       Int?
  reviewedAt          DateTime?
  reviewedById        Int?
  editedAt            DateTime?
  editedById          Int?
  hiddenAt            DateTime?
  rejectionReason     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  book                Book?              @relation(fields: [bookId], references: [id], onDelete: SetNull)
  reviewedBy          AdminUser?         @relation("ReviewedBy", fields: [reviewedById], references: [id])
  editedBy            AdminUser?         @relation("EditedBy", fields: [editedById], references: [id])
  studentRoster       StudentRoster?     @relation(fields: [studentRosterId], references: [id], onDelete: SetNull)

  @@index([bookId, status, createdAt])
  @@index([bookId, isFeatured, featuredOrder])
  @@index([studentSystemId, bookId])
}

model ImportBatch {
  id          Int          @id @default(autoincrement())
  fileName    String
  catalogName String
  importMode  ImportMode
  status      ImportStatus
  totalRows   Int
  successRows Int
  failedRows  Int
  failures    Json
  createdById Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   AdminUser?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  books       Book[]
}

model SiteAsset {
  id             Int      @id @default(1)
  schoolLogoPath String?
  carouselImages Json
  processContent Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StudentRoster {
  id           Int          @id @default(autoincrement())
  systemId     String       @unique
  studentName  String
  className    String
  seatNumber   String?
  gender       String?
  idCardSuffix String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reviews      BookReview[]

  @@index([studentName, className])
}

model SensitiveWord {
  id             Int      @id @default(autoincrement())
  word           String   @unique
  normalizedWord String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
